# Root ignore rules for both client and server

# dependencies
client/node_modules/
server/node_modules/
.pnp/
.pnp.js

# build outputs
client/build/
server/build/
server/dist/

# test and coverage outputs
client/coverage/
server/coverage/
coverage/

# environment files
.env
.env.local
.env.*.local
client/.env
client/.env.local
client/.env.*.local
server/.env
server/.env.local
server/.env.*.local

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# OS files
.DS_Store
Thumbs.db
